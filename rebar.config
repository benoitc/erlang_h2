{erl_opts, [debug_info, warnings_as_errors]}.
{deps, []}.

{project_plugins, [rebar3_ex_doc]}.

{ex_doc, [
    {source_url, <<"https://github.com/benoitc/h2">>},
    {extras, [<<"README.md">>, <<"docs/features.md">>]},
    {main, <<"README.md">>}
]}.

{profiles, [
    {test, [{deps, [{proper, "1.4.0"}]}]}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

{dialyzer, [
    {warnings, [
        error_handling,
        unmatched_returns
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.
