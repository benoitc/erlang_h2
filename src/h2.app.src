{application, h2,
 [{description, "HTTP/2 protocol library for Erlang"},
  {vsn, "0.10.2"},
  {registered, [eh2_sup]},
  {mod, {eh2_app, []}},
  {applications,
   [kernel,
    stdlib,
    ssl,
    crypto,
    public_key
   ]},
  {env,[]},
  {modules, []},
  {licenses, ["Apache-2.0"]},
  {links, [{"GitHub", "https://github.com/benoitc/erlang_h2"}]}
 ]}.
